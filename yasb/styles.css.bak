/* WEATHER WIDGET */
.weather-widget .icon {
	font-size: 16px;
	margin: 0 2px 1px 0;
}
.weather-widget .icon.sunnyDay {
	color: #fabd2f;
}
.weather-widget .icon.clearNight {
	color: #83a598;
	font-size: 22px;
	margin: 1px 2px 0px 0;
}
